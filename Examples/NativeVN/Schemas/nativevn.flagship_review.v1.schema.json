{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astra.invalid/schema/nativevn.flagship_review.v1.schema.json",
  "title": "NativeVN flagship review v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "package_id", "reviews"],
  "properties": {
    "schema": {"const": "nativevn.flagship_review.v1"},
    "package_id": {"const": "com.astra.nativevn.signal-glass-rain"},
    "reviews": {"type": "array", "items": {"$ref": "#/$defs/review"}}
  },
  "$defs": {
    "safe_symbol": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,127}$"},
    "relative_path": {"type": "string", "pattern": "^(?!/)(?!\\\\)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[^\\u0000]+$"},
    "private_alias": {"type": "string", "pattern": "^private://[a-z][a-z0-9._/-]{0,127}$"},
    "locator": {"type": "object", "additionalProperties": false, "properties": {"relative_path": {"$ref": "#/$defs/relative_path"}, "private_alias": {"$ref": "#/$defs/private_alias"}}, "oneOf": [{"required": ["relative_path"]}, {"required": ["private_alias"]}]},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "media": {"type": "object", "additionalProperties": false, "required": ["kind", "mime_type"], "properties": {"kind": {"enum": ["image", "font", "audio", "video", "vector", "document", "data"]}, "mime_type": {"type": "string"}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}, "duration_ms": {"type": "integer", "minimum": 1}, "sample_rate_hz": {"type": "integer", "minimum": 8000}, "channels": {"type": "integer", "minimum": 1}, "frame_rate": {"type": "number", "exclusiveMinimum": 0}, "color_space": {"enum": ["srgb", "display-p3", "linear-srgb", "unknown"]}, "has_alpha": {"type": "boolean"}, "codec": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"}}},
    "generation_source": {"type": "object", "additionalProperties": false, "required": ["kind", "method"], "properties": {"kind": {"enum": ["hand_authored", "code_native", "recorded", "licensed_source", "third_party_tool", "ai_assisted"]}, "method": {"$ref": "#/$defs/safe_symbol"}, "tool": {"$ref": "#/$defs/safe_symbol"}, "tool_version": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"}}},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "subject_id", "role", "artifact", "scene_id", "route_id", "line_id", "sha256", "byte_size", "media", "generation_source", "review_type", "reviewer_alias", "reviewed_on", "decision", "license_status", "release_eligible", "finding_codes"],
      "properties": {
        "id": {"$ref": "#/$defs/safe_symbol"},
        "subject_id": {"$ref": "#/$defs/safe_symbol"},
        "role": {"enum": ["content", "visual", "ui", "accessibility", "audio_model", "license", "voice", "release"]},
        "artifact": {"$ref": "#/$defs/locator"},
        "scene_id": {"$ref": "#/$defs/safe_symbol"},
        "route_id": {"$ref": "#/$defs/safe_symbol"},
        "line_id": {"$ref": "#/$defs/safe_symbol"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_size": {"type": "integer", "minimum": 1},
        "media": {"$ref": "#/$defs/media"},
        "generation_source": {"$ref": "#/$defs/generation_source"},
        "review_type": {"enum": ["content_creation", "visual_spec", "ui_tokens", "alt_text", "audio_model_review", "license", "voice_rights", "release_readiness"]},
        "reviewer_alias": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,63}$"},
        "reviewed_on": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "decision": {"enum": ["pass", "needs_changes", "blocked"]},
        "license_status": {"enum": ["pending", "blocked_voice_rights", "approved", "user_authorized", "not_applicable", "internal_only", "rejected"]},
        "release_eligible": {"type": "boolean"},
        "finding_codes": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/safe_symbol"}}
      },
      "allOf": [{"if": {"properties": {"release_eligible": {"const": true}}}, "then": {"properties": {"decision": {"const": "pass"}, "license_status": {"enum": ["approved", "user_authorized", "not_applicable"]}}}}]
    }
  }
}
