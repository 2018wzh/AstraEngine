{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astra.invalid/schema/nativevn.flagship_provenance.v1.schema.json",
  "title": "NativeVN flagship provenance v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "package_id", "records"],
  "properties": {
    "schema": {"const": "nativevn.flagship_provenance.v1"},
    "package_id": {"const": "com.astra.nativevn.signal-glass-rain"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "safe_symbol": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{0,127}$"},
    "relative_path": {"type": "string", "pattern": "^(?!/)(?!\\\\)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[^\\u0000]+$"},
    "private_alias": {"type": "string", "pattern": "^private://[a-z][a-z0-9._/-]{0,127}$"},
    "locator": {"type": "object", "additionalProperties": false, "properties": {"relative_path": {"$ref": "#/$defs/relative_path"}, "private_alias": {"$ref": "#/$defs/private_alias"}}, "oneOf": [{"required": ["relative_path"]}, {"required": ["private_alias"]}]},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generation_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "method"],
      "properties": {
        "kind": {"enum": ["hand_authored", "code_native", "recorded", "licensed_source", "third_party_tool", "ai_assisted"]},
        "method": {"$ref": "#/$defs/safe_symbol"},
        "tool": {"$ref": "#/$defs/safe_symbol"},
        "tool_version": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"},
        "input_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/locator"}}
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope", "evidence"],
      "properties": {
        "status": {"enum": ["pending", "blocked_voice_rights", "approved", "user_authorized", "not_applicable", "internal_only", "rejected"]},
        "scope": {"enum": ["internal_review", "public_redistribution", "reference_only"]},
        "evidence": {"$ref": "#/$defs/locator"},
        "expires_on": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "artifact", "scene_id", "route_id", "line_id", "sha256", "byte_size", "generation_source", "license", "release_eligible"],
      "properties": {
        "id": {"$ref": "#/$defs/safe_symbol"},
        "role": {"enum": ["background", "character", "prop", "ui_icon", "font", "voice", "bgm", "se", "video", "story_reference", "review_evidence"]},
        "artifact": {"$ref": "#/$defs/locator"},
        "scene_id": {"$ref": "#/$defs/safe_symbol"},
        "route_id": {"$ref": "#/$defs/safe_symbol"},
        "line_id": {"$ref": "#/$defs/safe_symbol"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_size": {"type": "integer", "minimum": 1},
        "media_attributes": {"type": "object", "additionalProperties": false, "properties": {"kind": {"$ref": "#/$defs/safe_symbol"}, "mime_type": {"type": "string"}, "width": {"type": "integer", "minimum": 1}, "height": {"type": "integer", "minimum": 1}, "duration_ms": {"type": "integer", "minimum": 1}, "sample_rate_hz": {"type": "integer", "minimum": 8000}, "channels": {"type": "integer", "minimum": 1}}},
        "generation_source": {"$ref": "#/$defs/generation_source"},
        "license": {"$ref": "#/$defs/license"},
        "release_eligible": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"release_eligible": {"const": true}}},
          "then": {
            "properties": {
              "license": {
                "properties": {
                  "status": {"enum": ["approved", "user_authorized", "not_applicable"]}
                }
              }
            }
          }
        }
      ]
    }
  }
}
