ui_view ui.tsui.modern.config model:astra.vn.ui_model.config.v1 theme:tsui.theme.modern #@id ui.tsui.modern.config
  screen id:root background:theme:surface.sky
    image id:sky_frame asset:theme:sky.frame min_width:800 min_height:600
    column id:gold position_x:23 position_y:29 position_right:23 position_bottom:29 background:theme:accent.gold min_width:754 min_height:542 padding:2
      column id:content background:theme:surface.paper min_width:718 min_height:538 padding:16 gap:5
        text id:title value:l10n:system.config font_size:26
        text id:master_label value:l10n:system.config.master_volume font_size:18
        slider id:master value:$model.master_volume min:0 max:100 step:1 min_height:42 background:theme:surface.button
          on change -> vn.set_config key:audio.master value:$event.value
        text id:speed_label value:l10n:system.config.text_speed font_size:18
        slider id:text_speed value:$model.text_speed min:0 max:100 step:1 min_height:42 background:theme:surface.button
          on change -> vn.set_config key:text.speed value:$event.value
        text id:auto_label value:l10n:system.config.auto_delay font_size:18
        slider id:auto_delay value:$model.auto_delay_ms min:100 max:10000 step:100 min_height:42 background:theme:surface.button
          on change -> vn.set_config key:auto.delay_ms value:$event.value
        toggle id:contrast value:$model.high_contrast label_key:l10n:system.config.high_contrast min_height:42 background:theme:surface.button_alt text_color:theme:text.on_dark indicator_color:theme:accent.gold indicator_off_color:theme:surface.speaker
          on change -> vn.set_config key:display.high_contrast value:$event.value
        text id:locale_label value:l10n:system.config.language font_size:18
        select id:locale value:$model.locale items:$model.available_locales min_height:42 background:theme:surface.button_alt text_color:theme:text.on_dark
          on change -> vn.set_config key:display.language value:$event.value
        button id:back text:l10n:system.back min_height:42 background:theme:surface.button text_color:theme:text.on_dark
          on activate -> vn.return_system

