{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FamilyPluginManifest",
  "type": "object",
  "required": [
    "abi_fingerprint",
    "binary_hash",
    "engine_version",
    "family_id",
    "feature_fingerprint",
    "package_eligible",
    "plugin_id",
    "provider_id",
    "rustc_fingerprint",
    "schema",
    "signature_algorithm",
    "signature_hex",
    "signer_identity",
    "supported_targets"
  ],
  "properties": {
    "abi_fingerprint": {
      "type": "string"
    },
    "binary_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "engine_version": {
      "type": "string"
    },
    "family_id": {
      "type": "string"
    },
    "feature_fingerprint": {
      "type": "string"
    },
    "native_manifest_hash": {
      "anyOf": [
        {
          "$ref": "#/definitions/Hash256"
        },
        {
          "type": "null"
        }
      ]
    },
    "package_eligible": {
      "type": "boolean"
    },
    "plugin_id": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "rustc_fingerprint": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "signature_algorithm": {
      "type": "string"
    },
    "signature_hex": {
      "type": "string"
    },
    "signer_identity": {
      "type": "string"
    },
    "supported_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Hash256": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    }
  }
}
