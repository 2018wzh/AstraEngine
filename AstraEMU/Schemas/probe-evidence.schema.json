{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProbeEvidence",
  "type": "object",
  "required": [
    "candidates",
    "case_alias",
    "case_fingerprint",
    "diagnostic_codes",
    "schema",
    "status"
  ],
  "properties": {
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProbeCandidateEvidence"
      }
    },
    "case_alias": {
      "type": "string"
    },
    "case_fingerprint": {
      "$ref": "#/definitions/Hash256"
    },
    "diagnostic_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "explicit_family_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema": {
      "type": "string"
    },
    "selected_family_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Hash256": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "ProbeCandidateEvidence": {
      "type": "object",
      "required": [
        "blocker_codes",
        "confidence_milli",
        "family_id",
        "marker_hashes",
        "provider_id"
      ],
      "properties": {
        "blocker_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence_milli": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0.0
        },
        "family_id": {
          "type": "string"
        },
        "marker_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Hash256"
          }
        },
        "provider_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
