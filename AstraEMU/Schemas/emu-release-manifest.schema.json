      }
    },
    "family_id": {
      "type": "string"
    },
    "family_provider_id": {
      "type": "string"
    },
    "required_platforms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_provider_id": {
      "type": "string"
    },
    "schema": {
      "type": "string"
    },
    "ui_provider_id": {
      "type": "string"
    }
  },
  "additionalProperties": false
