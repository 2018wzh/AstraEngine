        "type": "string"
      }
    },
    "plugin_id": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "report_redaction": {
      "type": "string"
    },
    "rustc_fingerprint": {
      "type": "string"
    },
    "supported_formats": {
