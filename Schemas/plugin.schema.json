{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Astra Plugin Descriptor",
  "type": "object",
  "required": ["id", "display_name", "version", "astra_api", "modules"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^astra\\.plugin\\.[a-z0-9_.-]+$" },
    "display_name": { "type": "string" },
    "version": { "type": "string" },
    "astra_api": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" }, "default": [] },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "entrypoint", "load_phase", "capabilities"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["runtime", "editor", "developer", "mcp", "cook", "compatibility"]
          },
          "entrypoint": { "type": "string" },
          "load_phase": {
            "type": "string",
            "enum": [
              "core_startup",
              "project_load",
              "asset_registry",
              "compatibility_probe",
              "runtime_startup",
              "editor_startup",
              "mcp_startup",
              "cook_startup"
            ]
          },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "permissions": { "type": "object" },
          "platforms": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
