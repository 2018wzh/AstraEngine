{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LegacyProbeReport",
  "type": "object",
  "required": [
    "blockers",
    "confidence_permyriad",
    "content_identity",
    "family_id",
    "markers"
  ],
  "properties": {
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/LegacyDiagnostic"
      }
    },
    "confidence_permyriad": {
      "type": "integer",
      "format": "uint16",
      "minimum": 0.0
    },
    "content_identity": {
      "$ref": "#/definitions/Hash256"
    },
    "family_id": {
      "$ref": "#/definitions/FamilyId"
    },
    "markers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "FamilyId": {
      "type": "string"
    },
    "Hash256": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "LegacyDiagnostic": {
      "type": "object",
      "required": [
        "code",
        "message",
        "severity",
        "subject"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "subject": {
          "type": "string"
        }
      }
    }
  }
}
