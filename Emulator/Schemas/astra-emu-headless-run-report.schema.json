{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HeadlessRunReportV1",
  "type": "object",
  "required": [
    "artifact_manifest_hash",
    "audio_meter_hash",
    "build_identity_hash",
    "checkpoints",
    "consumed_input_messages",
    "consumed_input_trace_hash",
    "diagnostic_codes",
    "engine_id",
    "entry_identity_hash",
    "family_provider_id",
    "fixed_steps",
    "game_identity_hash",
    "host_kind",
    "input_sequence_hash",
    "lifecycle_steps",
    "phase_timings",
    "presented_frames",
    "profile_hash",
    "runtime_provider_id",
    "runtime_state_trace_hash",
    "schema",
    "session_id_hash",
    "snapshot_round_trip_verified",
    "status",
    "terminal_reached",
    "vfs_access",
    "visual_trace_hash"
  ],
  "properties": {
    "artifact_manifest_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "audio_meter_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "build_identity_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/HeadlessCheckpointEvidenceV1"
      }
    },
    "consumed_input_messages": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "consumed_input_trace_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "diagnostic_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "engine_id": {
      "type": "string"
    },
    "entry_identity_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "family_provider_id": {
      "type": "string"
    },
    "fixed_steps": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "game_identity_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "host_kind": {
      "type": "string"
    },
    "input_sequence_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "lifecycle_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "phase_timings": {
      "$ref": "#/definitions/HeadlessPhaseTimingEvidenceV1"
    },
    "presented_frames": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "profile_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "resource_audit": {
      "anyOf": [
        {
          "$ref": "#/definitions/HeadlessResourceAuditEvidenceV1"
        },
        {
          "type": "null"
        }
      ]
    },
    "runtime_provider_id": {
      "type": "string"
    },
    "runtime_state_trace_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "schema": {
      "type": "string"
    },
    "session_id_hash": {
      "$ref": "#/definitions/Hash256"
    },
    "snapshot_round_trip_verified": {
      "type": "boolean"
    },
    "status": {
      "type": "string"
    },
    "terminal_reached": {
      "type": "boolean"
    },
    "vfs_access": {
      "$ref": "#/definitions/HeadlessVfsAccessEvidenceV1"
    },
    "visual_trace_hash": {
      "$ref": "#/definitions/Hash256"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Hash256": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      },
      "maxItems": 32,
      "minItems": 32
    },
    "HeadlessCheckpointEvidenceV1": {
      "type": "object",
      "required": [
        "checkpoint_id",
        "fixed_step",
        "frame_hash",
        "observation_hash"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string"
        },
        "fixed_step": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "frame_hash": {
          "$ref": "#/definitions/Hash256"
        },
        "observation_hash": {
          "$ref": "#/definitions/Hash256"
        }
      },
      "additionalProperties": false
    },
    "HeadlessDurationDistributionV1": {
      "type": "object",
      "required": [
        "max_ns",
        "median_ns",
        "p95_ns",
        "sample_count",
        "total_ns"
      ],
      "properties": {
        "max_ns": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "median_ns": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "p95_ns": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "sample_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "total_ns": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "HeadlessPhaseTimingEvidenceV1": {
      "type": "object",
      "required": [
        "effect_dispatch",
        "media",
        "present",
        "raster",
        "runtime_step",
        "step_total"
      ],
      "properties": {
        "effect_dispatch": {
          "$ref": "#/definitions/HeadlessDurationDistributionV1"
        },
        "media": {
          "$ref": "#/definitions/HeadlessDurationDistributionV1"
        },
        "present": {
          "$ref": "#/definitions/HeadlessDurationDistributionV1"
        },
        "raster": {
          "$ref": "#/definitions/HeadlessDurationDistributionV1"
        },
        "runtime_step": {
          "$ref": "#/definitions/HeadlessDurationDistributionV1"
        },
        "step_total": {
          "$ref": "#/definitions/HeadlessDurationDistributionV1"
        }
      },
      "additionalProperties": false
    },
    "HeadlessResourceAuditEvidenceV1": {
      "type": "object",
      "required": [
        "bytes_read",
        "manifest_hash",
        "max_range_bytes",
        "range_count",
        "resource_count"
      ],
      "properties": {
        "bytes_read": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "manifest_hash": {
          "$ref": "#/definitions/Hash256"
        },
        "max_range_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "range_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "resource_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "HeadlessVfsAccessEvidenceV1": {
      "type": "object",
      "required": [
        "bytes_read",
        "max_range_bytes",
        "read_count",
        "resource_count",
        "unique_range_count"
      ],
      "properties": {
        "bytes_read": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "max_range_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "read_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "resource_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "unique_range_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    }
  }
}
